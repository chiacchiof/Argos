OLLAMA_URL=http://localhost:11434
DEFAULT_MODEL=qwen3.5:latest
HOST=127.0.0.1
PORT=8000

# fetch_http user-agent (identificabile, no spoofing)
HTTP_USER_AGENT=AgentScraper/0.1 (+local research bot)
HTTP_TIMEOUT=20

# Soglie loop ReAct (override per progetto)
DEFAULT_MAX_ITERATIONS=10

# ============================================================
# Multi-tenant cloud DB (Fase 1 — vedi SETUP_CLOUD_DB_TENANT.md)
# Se DATABASE_URL è vuoto, l'app gira in modalità legacy single-user
# (no login, no tenant) come prima. Se è settato, viene abilitato
# il flusso login + tabelle tenants/users su Postgres.
# ============================================================

# Connection string Neon (region eu-central-1, project falling-salad-75878062).
# Sostituisci <PASSWORD> con la password vera dal dashboard Neon.
# DATABASE_URL=postgresql://neondb_owner:<PASSWORD>@ep-delicate-leaf-alnrwlji.c-3.eu-central-1.aws.neon.tech/neondb?sslmode=require

# Chiave per firmare i cookie di sessione. Generala una volta con:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
# Usa la STESSA chiave su tutti i PC del team (così i cookie restano validi
# se per qualche motivo si condivide una sessione di test).
# SESSION_SECRET_KEY=

# Bootstrap super-admin al primo boot su DB cloud vuoto. Lette UNA volta:
# se l'utente con quella email esiste già, viene ignorato. Cambia la
# password subito dopo il primo login.
# Per il pilot interno usiamo le credenziali fisse documentate in
# SETUP_CLOUD_DB_TENANT.md (edgAdmin / Entra123!).
# BOOTSTRAP_SUPER_ADMIN_EMAIL=edgAdmin
# BOOTSTRAP_SUPER_ADMIN_PASSWORD=Entra123!

# ============================================================
# Update banner (release check su GitHub)
# Se settati, l'app al boot chiama l'API GitHub `/repos/<repo>/releases/latest`
# (cache 6h, no blocco al boot) e mostra un banner giallo nell'header
# quando esiste una versione più recente di app.__version__.
# Se vuoto -> nessun banner, nessuna chiamata HTTP.
# Vedi anche: scripts/CLIENT_INSTALL.md sezione "Come faccio a vedere il banner".
# ============================================================

# Repo GitHub nel formato owner/repo. Es. chifer81/AgentScraper
# GITHUB_REPO=

# Token GitHub PAT, OBBLIGATORIO solo se il repo è privato. Scope richiesto:
# PAT classic con `repo`, oppure fine-grained con `Contents: Read`.
# GITHUB_TOKEN=

# ============================================================
# API key dei provider LLM remoti (browser-use)
# Imposta SOLO quelle che intendi usare. Mai committare questo file in git.
# ============================================================

# OpenAI — https://platform.openai.com
# OPENAI_API_KEY=sk-...

# Anthropic Claude — https://console.anthropic.com (endpoint OpenAI-compat)
# ANTHROPIC_API_KEY=sk-ant-...

# xAI Grok — https://x.ai/api
# XAI_API_KEY=xai-...

# Google Gemini — https://aistudio.google.com (endpoint OpenAI-compat)
# GEMINI_API_KEY=...

# Endpoint personalizzato OpenAI-compat (per provider 'custom')
# CUSTOM_API_KEY=...

# ============================================================
# Canali di messaggistica (per agent_mode=outreach/responder)
# ============================================================

# SMTP (invio email). Per Gmail: usa una "App Password", non la password normale.
# Configura host/port/user dalla pagina /settings; qui SOLO la password.
# SMTP_PASSWORD=...

# IMAP (ricezione email). Spesso uguale a SMTP_PASSWORD.
# IMAP_PASSWORD=...

# Telegram bot token (creato via @BotFather)
# TELEGRAM_BOT_TOKEN=12345:ABCdef...

# ===========================================================================
# WhatsApp outreach (agent_mode=outreach_whatsapp)
# ===========================================================================
# Motore A (browser automation): nessuna env richiesta. Account WA si
# aggiungono da /settings/whatsapp via QR-login (sessione persistita in
# data/whatsapp_sessions/<uuid>/).
#
# Motore B (Meta Cloud API): le credenziali si configurano da
# /settings/whatsapp salvandole CIFRATE nel DB (richiede AGENTSCRAPER_SECRET).
# Le seguenti env sono OPZIONALI: fallback se non c'è una whatsapp_api_config.

# META_WHATSAPP_ACCESS_TOKEN=         # Token Cloud API (Bearer)
# META_WHATSAPP_PHONE_NUMBER_ID=      # ID Meta del numero registrato
# META_WHATSAPP_BUSINESS_ACCOUNT_ID=  # WABA ID
# META_WHATSAPP_VERIFY_TOKEN=         # Per webhook (Fase 3 — non ancora attivo)

# Strategia engine selection (auto | A | B)
# WHATSAPP_DEFAULT_ENGINE=auto

# Rate-limit anti-ban Motore A
# WHATSAPP_A_MAX_PER_HOUR=30          # max DM/ora per account
# WHATSAPP_A_PAUSE_MIN_SEC=30         # pausa minima tra DM
# WHATSAPP_A_PAUSE_MAX_SEC=180        # pausa massima

# Cifratura access_token Meta + sessioni WA Browser: usa AGENTSCRAPER_SECRET
# già definita per outreach_social. Stessa chiave, gestita da
# app/agent/social/crypto_creds.py.
