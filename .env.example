OLLAMA_URL=http://localhost:11434
DEFAULT_MODEL=qwen3.5:latest
HOST=127.0.0.1
PORT=8000

# fetch_http user-agent. Default browser-like (Chrome moderno) per essere
# accettato da siti con anti-bot semplici. Cambia a un identificativo "leale"
# tipo `Argos/0.1 (+local research bot)` se preferisci essere identificabile.
HTTP_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0.0.0 Safari/537.36
HTTP_TIMEOUT=20

# Soglie loop ReAct (override per progetto)
DEFAULT_MAX_ITERATIONS=10

# ============================================================
# Multi-tenant cloud DB (Fase 1 — vedi SETUP_CLOUD_DB_TENANT.md)
# Se DATABASE_URL è vuoto, l'app gira in modalità legacy single-user
# (no login, no tenant) come prima. Se è settato, viene abilitato
# il flusso login + tabelle tenants/users su Postgres.
# ============================================================

# Connection string Neon (region eu-central-1, project falling-salad-75878062).
# Sostituisci <PASSWORD> con la password vera dal dashboard Neon.
# DATABASE_URL=postgresql://neondb_owner:<PASSWORD>@ep-delicate-leaf-alnrwlji.c-3.eu-central-1.aws.neon.tech/neondb?sslmode=require

# ---- Tuning del connection pool (override del default; sicuro lasciarli vuoti) ----
# Su DB remoto (Neon/Azure) la latenza è ~30-60ms per query. Per evitare che
# l'UI sia lenta:
#  - min_size alto = N connessioni warm sempre pronte (niente handshake TLS
#    nel critical path delle richieste HTMX parallele)
#  - max_size = tetto (resta sotto i limiti free di Neon/Azure)
#  - max_idle = riciclo connessioni idle (anti-firewall/NAT killer)
# DATABASE_POOL_MIN_SIZE=4
# DATABASE_POOL_MAX_SIZE=10
# DATABASE_POOL_TIMEOUT=10
# DATABASE_POOL_MAX_IDLE=300

# Se usi un pooler PgBouncer-like (Neon -pooler, Supabase 6543, Azure dietro
# pgbouncer) i prepared statements server-side di psycopg3 si rompono. Setta
# a 1 per disabilitarli. Auto-rilevato se hostname contiene '-pooler' o
# 'pgbouncer' o se porta=6543.
# DATABASE_DISABLE_PREPARED=1

# Chiave per firmare i cookie di sessione. Generala una volta con:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
# Usa la STESSA chiave su tutti i PC del team (così i cookie restano validi
# se per qualche motivo si condivide una sessione di test).
# SESSION_SECRET_KEY=

# Bootstrap super-admin al primo boot su DB cloud vuoto. Lette UNA volta:
# se l'utente con quella email esiste già, viene ignorato. Cambia la
# password subito dopo il primo login.
# Per il pilot interno usiamo le credenziali fisse documentate in
# SETUP_CLOUD_DB_TENANT.md (edgAdmin / Entra123!).
# BOOTSTRAP_SUPER_ADMIN_EMAIL=edgAdmin
# BOOTSTRAP_SUPER_ADMIN_PASSWORD=Entra123!

# ============================================================
# Update banner (release check su GitHub)
# Se settati, l'app al boot chiama l'API GitHub `/repos/<repo>/releases/latest`
# (cache 6h, no blocco al boot) e mostra un banner giallo nell'header
# quando esiste una versione più recente di app.__version__.
# Se vuoto -> nessun banner, nessuna chiamata HTTP.
# Vedi anche: scripts/CLIENT_INSTALL.md sezione "Come faccio a vedere il banner".
# ============================================================

# Repo GitHub nel formato owner/repo. Es. chiacchiof/Argos
# GITHUB_REPO=

# Token GitHub PAT, OBBLIGATORIO solo se il repo è privato. Scope richiesto:
# PAT classic con `repo`, oppure fine-grained con `Contents: Read`.
# GITHUB_TOKEN=

# ============================================================
# API key dei provider LLM remoti (OpenAI, Anthropic, xAI, Gemini, custom)
# ------------------------------------------------------------
# Si configurano dall'UI: /accounts/llm-keys
# Le chiavi sono cifrate Fernet con ARGOS_SECRET, scoped al tenant, con
# label simbolico (es. "prod", "dev"), status (active/quarantine/banned),
# audit di chi le ha create. NIENTE chiavi in .env.
#
# (Le vecchie env vars OPENAI_API_KEY/ANTHROPIC_API_KEY/ecc. restano come
#  fallback solo per back-compat: non aggiungerle a nuove installazioni.)
# ============================================================
# Canali di messaggistica (per agent_mode=outreach/responder)
# ------------------------------------------------------------
# Si configurano dall'UI (cifrati con ARGOS_SECRET):
#  - /accounts/email        → email SMTP/IMAP (multi-account)
#  - /accounts/messaging    → bot Telegram (multi-account)
#
# Le vecchie env vars SMTP_PASSWORD / IMAP_PASSWORD / TELEGRAM_BOT_TOKEN
# vengono LETTE UNA VOLTA al boot dalla migration legacy
# (db.migrate_legacy_channels_to_accounts) per creare un account
# "legacy-default". Dopo la prima migration non servono più — gestisci
# tutto dall'UI.
# ============================================================

# ===========================================================================
# WhatsApp outreach (agent_mode=outreach_whatsapp)
# ===========================================================================
# Motore A (browser automation): nessuna env richiesta. Account WA si
# aggiungono da /accounts/messaging?tab=browser via QR-login (sessione
# persistita in data/whatsapp_sessions/<uuid>/).
#
# Motore B (Meta Cloud API): le credenziali si configurano da
# /accounts/messaging?tab=api salvandole CIFRATE nel DB (richiede ARGOS_SECRET).
# Le seguenti env sono OPZIONALI: fallback se non c'è una whatsapp_api_config.

# META_WHATSAPP_ACCESS_TOKEN=         # Token Cloud API (Bearer)
# META_WHATSAPP_PHONE_NUMBER_ID=      # ID Meta del numero registrato
# META_WHATSAPP_BUSINESS_ACCOUNT_ID=  # WABA ID
# META_WHATSAPP_VERIFY_TOKEN=         # Per webhook (Fase 3 — non ancora attivo)

# Strategia engine selection (auto | A | B)
# WHATSAPP_DEFAULT_ENGINE=auto

# Rate-limit anti-ban Motore A
# WHATSAPP_A_MAX_PER_HOUR=30          # max DM/ora per account
# WHATSAPP_A_PAUSE_MIN_SEC=30         # pausa minima tra DM
# WHATSAPP_A_PAUSE_MAX_SEC=180        # pausa massima

# Cifratura access_token Meta + sessioni WA Browser: usa ARGOS_SECRET
# già definita per outreach_social. Stessa chiave, gestita da
# app/agent/social/crypto_creds.py.

# ===========================================================================
# ARGOS_SECRET — master key Fernet per cifratura credenziali (social, email,
# telegram bots, whatsapp). Minimo 16 caratteri (raccomandato 30+).
# Genera una volta con: python -c "import secrets; print(secrets.token_urlsafe(40))"
# IMPORTANTE: cambiare questa chiave RENDE INDECIFRABILI tutti gli account già
# salvati. Salvala in un password manager.
#
# Back-compat: se hai ancora AGENTSCRAPER_SECRET (pre-rebrand 2026-05-21),
# l'app continua a leggerla come fallback. Migra appena puoi.
# ===========================================================================
# ARGOS_SECRET=

# ===========================================================================
# ARGOS_PROXIES — JSON con lista di proxy per outreach_social/recon (opzionale).
# Esempio:
#   ARGOS_PROXIES='[{"label":"ip1","url":"http://user:pass@host:8080","country":"IT"}]'
# Back-compat: AGENTSCRAPER_PROXIES funziona ancora come fallback.
# ===========================================================================
# ARGOS_PROXIES=
